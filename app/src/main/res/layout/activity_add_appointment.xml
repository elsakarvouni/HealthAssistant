<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".AddAppointmentActivity">

    <include
        android:id="@+id/myHeader"
        layout="@layout/layout_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@+id/myHeader"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavLayout">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/lblTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Προσθήκη Ραντεβού"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#4CAF50"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <EditText
                android:id="@+id/edtDocName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Όνομα Γιατρού"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/lblTitle" />

            <EditText
                android:id="@+id/edtSpecialty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ειδικότητα"
                app:layout_constraintTop_toBottomOf="@id/edtDocName" />

            <EditText
                android:id="@+id/edtAppDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ημερομηνία Ραντεβού"
                android:focusable="false"
                android:clickable="true"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/edtSpecialty" />

            <EditText
                android:id="@+id/edtAppTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Ώρα Ραντεβού"
                android:focusable="false"
                android:clickable="true"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/edtAppDate" />

            <EditText
                android:id="@+id/edtDocPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Τηλέφωνο Γιατρού"
                android:inputType="phone"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/edtAppTime" />

            <Button
                android:id="@+id/btnSaveAppointment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Αποθήκευση"
                android:backgroundTint="#4CAF50"
                android:layout_marginTop="24dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="50dp"
                android:layout_marginEnd="50dp"
                app:layout_constraintTop_toBottomOf="@id/edtDocPhone" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavLayout"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="#EEEEEE"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/navEdit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_menu_edit" />

        <ImageButton
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_menu_today" />

        <ImageButton
            android:id="@+id/navCalendar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_menu_my_calendar" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>