<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".EditMedicineActivity">

    <include
        android:id="@+id/myHeader"
        layout="@layout/layout_header" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@+id/myHeader"
        app:layout_constraintBottom_toTopOf="@+id/bottomNavLayout">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <TextView
                android:id="@+id/lblSelect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="14sp"
                android:textStyle="bold"
                android:text="Επιλέξτε φάρμακο για επεξεργασία:"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <Spinner
                android:id="@+id/spnMedicines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                app:layout_constraintTop_toBottomOf="@id/lblSelect" />

            <TextView
                android:id="@+id/lblEditNameTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Όνομα Φαρμάκου:"
                android:textStyle="bold"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/spnMedicines"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/editName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/med_name"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@id/lblEditNameTitle" />

            <TextView
                android:id="@+id/lblEditDescTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Περιγραφή:"
                android:textStyle="bold"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/editName"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/editDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/description"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@id/lblEditDescTitle" />

            <TextView
                android:id="@+id/lblEditTypeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Τύπος Φαρμάκου:"
                android:textStyle="bold"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/editDesc"
                app:layout_constraintStart_toStartOf="parent" />

            <Spinner
                android:id="@+id/spnMedType"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:minHeight="48dp"
                android:background="@android:drawable/btn_dropdown"
                app:layout_constraintTop_toBottomOf="@id/lblEditTypeTitle" />

            <LinearLayout
                android:id="@+id/layoutInventoryTitles"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/spnMedType">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Συνολικό Απόθεμα:"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Δόση ανά φορά:"
                    android:textStyle="bold"
                    android:textSize="14sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutInventory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@id/layoutInventoryTitles">

                <EditText
                    android:id="@+id/edtInventory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Ποσότητα"
                    android:inputType="numberDecimal" />

                <EditText
                    android:id="@+id/edtDose"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:hint="Δόση"
                    android:inputType="numberDecimal" />
            </LinearLayout>

            <TextView
                android:id="@+id/lblEditStartDateTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Ημερομηνία Έναρξης:"
                android:textStyle="bold"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/layoutInventory"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/editStartDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/start_date"
                android:focusable="false"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@id/lblEditStartDateTitle" />

            <TextView
                android:id="@+id/lblEditDateTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Ημερομηνία Λήξης:"
                android:textStyle="bold"
                android:textSize="14sp"
                app:layout_constraintTop_toBottomOf="@id/editStartDate"
                app:layout_constraintStart_toStartOf="parent" />

            <EditText
                android:id="@+id/editDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/exp_date"
                android:focusable="false"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@id/lblEditDateTitle" />

            <LinearLayout
                android:id="@+id/containerHours"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/editDate"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/lblHoursTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ώρες Λήψης:"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="6dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/containerDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                app:layout_constraintTop_toBottomOf="@id/containerHours"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/lblDaysTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ημέρες Επανάληψης:"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="4dp">

                    <CheckBox android:id="@+id/chkMon" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Δευ" />
                    <CheckBox android:id="@+id/chkTue" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Τρι" />
                    <CheckBox android:id="@+id/chkWed" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Τετ" />
                    <CheckBox android:id="@+id/chkThu" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Πεμ" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <CheckBox android:id="@+id/chkFri" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Παρ" />
                    <CheckBox android:id="@+id/chkSat" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Σαβ" />
                    <CheckBox android:id="@+id/chkSun" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Κυρ" />
                    <CheckBox android:id="@+id/chkSelectAll" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="ΟΛΑ" android:textStyle="bold" android:textColor="#4CAF50" />
                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/btnUpdate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/update"
                android:layout_marginTop="28dp"
                app:layout_constraintTop_toBottomOf="@id/containerDays"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"/>

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/delete"
                android:backgroundTint="#F44336"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                app:layout_constraintTop_toBottomOf="@id/btnUpdate"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavLayout"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:background="#EEEEEE"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageButton
            android:id="@+id/navEdit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_menu_edit" />

        <ImageButton
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_menu_today" />

        <ImageButton
            android:id="@+id/navCalendar"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?attr/selectableItemBackground"
            android:src="@android:drawable/ic_menu_my_calendar" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>